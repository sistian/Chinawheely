  <div class="toast" id="toast"><span id="toastIcon">✓</span><span id="toastMessage">Message</span></div>

  <!-- Payment Modal -->
  <div class="modal-overlay" id="paymentModal">
    <div class="payment-modal">
      <div class="payment-modal-header">
        <h3>Complete Your Booking</h3>
        <button type="button" class="modal-close" onclick="closePaymentModal()">&times;</button>
      </div>
      <div class="payment-modal-body">
        <!-- Order Summary -->
        <div class="order-summary" id="modalOrderSummary">
          <div class="order-summary-row"><span>Service</span><span id="modalService">-</span></div>
          <div class="order-summary-row"><span>City</span><span id="modalCity">-</span></div>
          <div class="order-summary-row"><span>Route</span><span id="modalRoute">-</span></div>
          <div class="order-summary-row"><span>Date & Time</span><span id="modalDateTime">-</span></div>
          <div class="order-summary-row"><span>Vehicle</span><span id="modalVehicle">-</span></div>
          <div class="order-summary-row"><span>Passengers</span><span id="modalPassengers">-</span></div>
          <div class="order-summary-row total"><span>Estimated Total</span><span id="modalPrice">-</span></div>
        </div>

        <!-- Price Display -->
        <div class="price-display">
          <div class="price-usd" id="modalPriceUsd">$0</div>
          <div class="price-cny">≈ <span class="cny-amount" id="modalPriceCny">¥0</span> CNY</div>
        </div>

        <!-- Payment Tabs -->
        <div class="payment-tabs">
          <button type="button" class="payment-tab active" onclick="switchPaymentTab('paypal')">PayPal</button>
          <button type="button" class="payment-tab" onclick="switchPaymentTab('alipay')">Alipay</button>
