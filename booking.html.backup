  </div>

  <!-- Floating WhatsApp Button -->
  <button class="fab-whatsapp" onclick="openWhatsappModal()" aria-label="Chat on WhatsApp">
    <img src="images/whatsapp-btn.png" alt="WhatsApp">
  </button>

  <script src="scripts.js"></script>
  <script>
    // City tiers for pricing
    const tier1Cities = ['beijing', 'shanghai', 'guangzhou', 'shenzhen'];
    const tier2Cities = ['chengdu', 'wuhan', 'hangzhou', 'chongqing'];

    function getCityTierMultiplier(city) {
      if (tier1Cities.includes(city)) return 1.0;
      if (tier2Cities.includes(city)) return 0.8;
      return 0.85; // default for other cities
    }
    function updateForm() {
      const serviceType = document.querySelector('input[name="serviceType"]:checked').value;
      const city = document.getElementById('city').value;
      const vehicle = document.querySelector('input[name="vehicle"]:checked').value;
      const date = document.getElementById('date').value;
      const time = document.getElementById('time').value;
      const passengers = document.getElementById('passengers').value;
      const pickup = document.getElementById('pickup').value;
      const dropoff = document.getElementById('dropoff').value;
      const hours = document.getElementById('hours').value;
      const fromCity = document.getElementById('fromCity').value;
      const toCity = document.getElementById('toCity').value;

      // Toggle fields based on service type
      document.getElementById('airportFields').style.display = serviceType === 'airport' ? 'block' : 'none';
      document.getElementById('cityFields').style.display = serviceType === 'city' ? 'block' : 'none';
      document.getElementById('intercityFields').style.display = serviceType === 'intercity' ? 'block' : 'none';
      document.getElementById('flightGroup').style.display = serviceType === 'airport' ? 'block' : 'none';

      // Update summary
      document.getElementById('summaryService').textContent = 
        serviceType === 'airport' ? 'Airport Transfer' : 
        serviceType === 'city' ? 'City Car Service' : 'Intercity Trip';

      document.getElementById('summaryCity').textContent = city ? 
        city.charAt(0).toUpperCase() + city.slice(1) : '-';

      let routeText = '-';
      if (serviceType === 'airport' && pickup && dropoff) {
        routeText = `${pickup.charAt(0).toUpperCase() + pickup.slice(1)} → ${dropoff.charAt(0).toUpperCase() + dropoff.slice(1)}`;
      } else if (serviceType === 'city') {
        routeText = `${hours} hours`;
      } else if (serviceType === 'intercity' && fromCity && toCity) {
        routeText = `${fromCity} → ${toCity}`;
      }
      document.getElementById('summaryRoute').textContent = routeText;

      document.getElementById('summaryDateTime').textContent = (date && time) ? `${date} ${time}` : '-';
      document.getElementById('summaryVehicle').textContent = vehicle.charAt(0).toUpperCase() + vehicle.slice(1);
      document.getElementById('summaryPassengers').textContent = passengers;

      // Calculate price
      const basePrices = { economy: 51, business: 81, mpv: 104 };
      let price = basePrices[vehicle] || 51;

      // City tier multiplier
      price *= getCityTierMultiplier(city);

      // Service type multiplier
      if (serviceType === 'city') {
        const hourMultiplier = { '4': 1, '8': 1.8, '12': 2.5 };
        price *= (hourMultiplier[hours] || 1.8);
      } else if (serviceType === 'intercity') {
        price *= 1.5;
      }

      // Round to nearest 5
      price = Math.round(price / 5) * 5;
      document.getElementById('summaryPrice').textContent = `$${price}`;

      // Update vehicle price labels
      document.querySelectorAll('.vehicle-price').forEach(el => {
        const base = parseInt(el.dataset.base);
        let vPrice = base * getCityTierMultiplier(city);
        if (serviceType === 'city') vPrice *= 1.8;
        if (serviceType === 'intercity') vPrice *= 1.5;
        vPrice = Math.round(vPrice / 5) * 5;
        el.textContent = `From $${vPrice}`;
      });

      // Extras
      const extras = Array.from(document.querySelectorAll('input[name="extras"]:checked')).map(el => {
        const map = { childseat: 'Child Seat', meetgreet: 'Meet & Greet', wifi: 'WiFi' };
        return map[el.value];
      });
      if (extras.length > 0) {
        document.getElementById('summaryExtrasRow').style.display = 'flex';
        document.getElementById('summaryExtras').textContent = extras.join(', ');
      } else {
        document.getElementById('summaryExtrasRow').style.display = 'none';
      }
    }

    // Set default date to tomorrow
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    document.getElementById('date').value = tomorrow.toISOString().split('T')[0];
    document.getElementById('time').value = '10:00';

    // Form submission — show payment modal
    let currentPrice = 0;
    let exchangeRate = 7.25;

    document.getElementById('bookingForm').addEventListener('submit', function(e) {
      e.preventDefault();

      // Validate
      if (!document.getElementById('city').value) {
        showToast('Please select a city', 'error');
        return;
      }
      if (!document.getElementById('firstName').value || !document.getElementById('lastName').value) {
        showToast('Please enter your full name', 'error');
        return;
      }
      if (!document.getElementById('email').value || !document.getElementById('phone').value) {
        showToast('Please enter your contact details', 'error');
        return;
      }

      // Get current computed price
      const serviceType = document.querySelector('input[name="serviceType"]:checked').value;
      const city = document.getElementById('city').value;
      const vehicle = document.querySelector('input[name="vehicle"]:checked').value;
      const date = document.getElementById('date').value;
      const time = document.getElementById('time').value;
      const passengers = document.getElementById('passengers').value;
      const pickup = document.getElementById('pickup').value;
      const dropoff = document.getElementById('dropoff').value;
      const hours = document.getElementById('hours').value;
      const fromCity = document.getElementById('fromCity').value;
      const toCity = document.getElementById('toCity').value;
      const firstName = document.getElementById('firstName').value;
      const lastName = document.getElementById('lastName').value;

      const basePrices = { economy: 51, business: 81, mpv: 104 };
      currentPrice = basePrices[vehicle] || 51;
      currentPrice *= getCityTierMultiplier(city);
      if (serviceType === 'city') {
        const hourMultiplier = { '4': 1, '8': 1.8, '12': 2.5 };
        currentPrice *= (hourMultiplier[hours] || 1.8);
      } else if (serviceType === 'intercity') {
        currentPrice *= 1.5;
      }
      currentPrice = Math.round(currentPrice / 5) * 5;

      // Populate modal
      document.getElementById('modalService').textContent =
        serviceType === 'airport' ? 'Airport Transfer' :
        serviceType === 'city' ? 'City Car Service' : 'Intercity Trip';
      document.getElementById('modalCity').textContent = city ? city.charAt(0).toUpperCase() + city.slice(1) : '-';

      let routeText = '-';
      if (serviceType === 'airport' && pickup && dropoff) {
        routeText = `${pickup.charAt(0).toUpperCase() + pickup.slice(1)} → ${dropoff.charAt(0).toUpperCase() + dropoff.slice(1)}`;
      } else if (serviceType === 'city') {
        routeText = `${hours} hours`;
      } else if (serviceType === 'intercity' && fromCity && toCity) {
        routeText = `${fromCity} → ${toCity}`;
      }
      document.getElementById('modalRoute').textContent = routeText;
      document.getElementById('modalDateTime').textContent = (date && time) ? `${date} ${time}` : '-';
      document.getElementById('modalVehicle').textContent = vehicle.charAt(0).toUpperCase() + vehicle.slice(1);
      document.getElementById('modalPassengers').textContent = passengers;
      document.getElementById('modalPrice').textContent = `$${currentPrice}`;
      document.getElementById('modalPriceUsd').textContent = `$${currentPrice}`;

      // Fetch exchange rate and show modal
      document.getElementById('modalPriceCny').textContent = `¥${Math.round(currentPrice * exchangeRate)}`;
      fetch('https://open.er-api.com/v6/latest/USD')
        .then(r => r.json())
        .then(data => {
          if (data && data.rates && data.rates.CNY) {
            exchangeRate = data.rates.CNY;
            document.getElementById('modalPriceCny').textContent = `¥${Math.round(currentPrice * exchangeRate)}`;
          }
        })
        .catch(() => {
          // fallback already set
        });

      // Show modal
      document.getElementById('paymentModal').classList.add('active');
      document.body.style.overflow = 'hidden';
    });

    function closePaymentModal() {
      document.getElementById('paymentModal').classList.remove('active');
      document.body.style.overflow = '';
    }

    function switchPaymentTab(tab) {
      document.querySelectorAll('.payment-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.payment-tab-content').forEach(c => c.classList.remove('active'));
      document.querySelector(`.payment-tab[onclick="switchPaymentTab('${tab}')"]`).classList.add('active');
      document.getElementById('tab-' + tab).classList.add('active');
    }

    function openWhatsappModal() {
      document.getElementById('whatsappModal').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeWhatsappModal() {
      document.getElementById('whatsappModal').classList.remove('active');
      document.body.style.overflow = '';
    }

    function submitBooking() {
      document.getElementById('bookingForm').submit();
    }

    // Close modals on overlay click
    document.getElementById('paymentModal').addEventListener('click', function(e) {
      if (e.target === this) closePaymentModal();
    });
    document.getElementById('whatsappModal').addEventListener('click', function(e) {
      if (e.target === this) closeWhatsappModal();
    });

    // Close modals on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closePaymentModal();
        closeWhatsappModal();
      }
    });

    // Initialize
    updateForm();
  </script>

</body>
</html>
