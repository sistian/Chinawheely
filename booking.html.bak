<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://formsubmit.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://open.er-api.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formsubmit.co;">
  <meta http-equiv="X-Content-Type-Options" content="nosniff">
  <meta http-equiv="X-Frame-Options" content="DENY">
  <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Book Private Car & Airport Transfer in China | Chinawheely</title>
  <meta name="description" content="Book your airport transfer or private car in China in under 2 minutes. Fixed price, English-speaking driver, free flight tracking. No account required.">
  <meta name="keywords" content="book private car China, airport transfer booking, China car service reservation, Beijing airport pickup book, Shanghai private driver hire">
  <link rel="canonical" href="https://www.Chinawheely.com/booking.html">
  
  <!-- Open Graph -->
  <meta property="og:title" content="Book Private Car & Airport Transfer in China | Chinawheely">
  <meta property="og:description" content="Book airport transfer or private car service in China in under 2 minutes. English-speaking driver, fixed price, free flight tracking.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.Chinawheely.com/booking.html">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Book Private Car & Airport Transfer in China | Chinawheely">
  <meta name="twitter:description" content="Book airport transfer or private car service in China in under 2 minutes. English-speaking driver, fixed price, free flight tracking.">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
  
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Book Private Car & Airport Transfer in China",
    "description": "Book airport transfer or private car service in China in under 2 minutes. English-speaking driver, fixed price, free flight tracking.",
    "url": "https://www.Chinawheely.com/booking.html",
    "mainEntity": {
      "@type": "Service",
      "name": "China Private Car Booking",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Chinawheely",
        "telephone": "+86-155-2777-1775",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Wuhan",
          "addressRegion": "Hubei",
          "addressCountry": "CN"
        }
      },
      "areaServed": {
        "@type": "Country",
        "name": "China"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Private Car Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Airport Transfers",
              "description": "Private airport pickup and drop-off"
            },
            "price": "51.00",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "City Charter Car",
              "description": "Full day private car with driver"
            },
            "price": "345.00",
            "priceCurrency": "USD"
          }
        ]
      }
    }
  }
  </script>
  <style>
    /* ===== Payment Modal ===== */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 10000;
      padding: var(--space-4);
    }
    .modal-overlay.active { display: flex; }
    .payment-modal {
      background: #fff;
      border-radius: var(--radius-lg);
      width: 100%;
      max-width: 520px;
      max-height: 85vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      animation: modalIn 0.25s ease;
    }
    @keyframes modalIn {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0)    scale(1); }
    }
    .payment-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-5) var(--space-6) var(--space-4);
      border-bottom: 1px solid var(--color-gray-100);
      position: sticky;
      top: 0;
      background: #fff;
      z-index: 2;
    }
    .payment-modal-header h3 {
      font-size: var(--text-xl);
      font-weight: 700;
      margin: 0;
    }
    .modal-close {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--color-gray-400);
      line-height: 1;
      padding: 0;
      width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      border-radius: var(--radius-md);
      transition: background var(--transition-fast);
    }
    .modal-close:hover { background: var(--color-gray-100); color: var(--color-gray-700); }
    .payment-modal-body { padding: var(--space-5) var(--space-6); }

    /* Order summary */
    .order-summary {
      background: var(--color-gray-50);
      border-radius: var(--radius-md);
      padding: var(--space-4);
      margin-bottom: var(--space-5);
    }
    .order-summary-row {
      display: flex;
      justify-content: space-between;
      font-size: var(--text-sm);
      color: var(--color-gray-600);
      padding: var(--space-1) 0;
    }
    .order-summary-row.total {
      font-weight: 700;
      color: var(--color-gray-900);
      font-size: var(--text-base);
      border-top: 1px dashed var(--color-gray-200);
      margin-top: var(--space-2);
      padding-top: var(--space-2);
    }

    /* Price display */
    .price-display {
      text-align: center;
      margin-bottom: var(--space-5);
    }
    .price-usd {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--color-primary);
      line-height: 1;
    }
    .price-cny {
      font-size: var(--text-lg);
      color: var(--color-gray-500);
      margin-top: var(--space-1);
    }
    .price-cny .cny-amount { font-weight: 700; color: var(--color-gray-700); }

    /* Payment tabs */
    .payment-tabs {
      display: flex;
      gap: var(--space-2);
      margin-bottom: var(--space-4);
    }
    .payment-tab {
      flex: 1;
      padding: var(--space-3) var(--space-4);
      border: 2px solid var(--color-gray-200);
      border-radius: var(--radius-md);
      background: #fff;
      cursor: pointer;
      font-weight: 600;
      font-size: var(--text-sm);
      text-align: center;
      transition: all var(--transition-fast);
    }
    .payment-tab.active {
      border-color: var(--color-primary);
      background: var(--color-primary-50);
      color: var(--color-primary);
    }
    .payment-tab:hover:not(.active) { border-color: var(--color-gray-300); }
    .payment-tab-content { display: none; }
    .payment-tab-content.active { display: block; }

    /* QR section */
    .qr-section {
      text-align: center;
      padding: var(--space-4);
      background: var(--color-gray-50);
      border-radius: var(--radius-md);
    }
    .qr-section img {
      width: 180px; height: 180px;
      object-fit: contain;
      border-radius: var(--radius-md);
      margin-bottom: var(--space-3);
    }
    .qr-note {
      background: #fff9c4;
      border-left: 4px solid #f9a825;
      padding: var(--space-3) var(--space-4);
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
      font-size: var(--text-sm);
      color: var(--color-gray-700);
      margin-top: var(--space-3);
      text-align: left;
    }

    /* WhatsApp in modal */
    .modal-whatsapp {
      margin-top: var(--space-5);
      padding-top: var(--space-5);
      border-top: 1px solid var(--color-gray-100);
      text-align: center;
    }
    .modal-whatsapp img {
      width: 120px; height: 120px;
      object-fit: contain;
      border-radius: var(--radius-md);
      margin-bottom: var(--space-2);
    }
    .modal-whatsapp p { font-size: var(--text-sm); color: var(--color-gray-600); margin: var(--space-1) 0; }
    .modal-whatsapp a { color: var(--color-primary); font-weight: 600; }

    /* Contact info */
    .modal-contact {
      margin-top: var(--space-4);
      padding: var(--space-3);
      background: var(--color-gray-50);
      border-radius: var(--radius-md);
      text-align: center;
      font-size: var(--text-sm);
      color: var(--color-gray-600);
    }
    .modal-contact a { color: var(--color-primary); font-weight: 600; }

    /* Submit button */
    .btn-submit {
      width: 100%;
      margin-top: var(--space-4);
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav class="nav" id="navbar">
    <div class="container nav-inner">
      <a href="index.html" class="nav-logo">
        <img src="images/logo.png" alt="Chinawheely Logo" class="nav-logo-img" style="height:40px;width:auto;">
        <span class="nav-brand-text">之二虫<sup>®</sup></span>
        <span class="nav-brand-sep">|</span>
        <span>Chinawheely</span>
      </a>
      <ul class="nav-links">
        <li><a href="index.html#services">Services</a></li>
        <li><a href="index.html#cities">Cities</a></li>
        <li><a href="index.html#how-it-works">How It Works</a></li>
        <li><a href="index.html#pricing">Pricing</a></li>
        <li><a href="index.html#faq">FAQ</a></li>
      </ul>
      <div class="nav-cta">
        <span class="nav-phone">+86-15527771775</span>
      </div>
    <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>

    </div>
  </nav>

<!-- Mobile Menu -->
<div id="mobileMenu" style="display:none;position:fixed;top:72px;left:0;right:0;bottom:0;background:rgba(255,255,255,0.98);z-index:999;padding:2rem;flex-direction:column;gap:1.5rem;">
  <a href="index.html">Home</a>
  <a href="services.html">Services</a>
  <a href="index.html#cities">Cities</a>
  <a href="booking.html">Book Now</a>
</div>

  <!-- Booking Section -->
  <section class="booking-section">
    <div class="container booking-container">
      <!-- Booking Form -->
      <div class="booking-form-card">
        <h2 style="margin-bottom:var(--space-2);">Book Your Ride</h2>
        <p style="color:var(--color-gray-500);margin-bottom:var(--space-8);">Fill in your details below. You'll get a fixed price instantly.</p>

        <form id="bookingForm" action="https://formsubmit.co/ef5e07ff710b617bdc42401c730e609b" method="POST" novalidate>
          <input type="hidden" name="_next" value="https://www.Chinawheely.com/thank-you.html">
          <input type="hidden" name="_subject" value="New Booking - Chinawheely">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">
          <input type="hidden" name="price" id="formPrice" value="">
          <input type="hidden" name="routeSummary" id="formRouteSummary" value="">
          <input type="hidden" name="serviceTypeLabel" id="formServiceType" value="">
          <input type="hidden" name="vehicleLabel" id="formVehicleLabel" value="">
          <!-- Honeypot field - hidden from humans, traps bots -->
          <div style="position:absolute;left:-9999px;opacity:0;">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
          </div>
          <!-- Service Type -->
          <div class="form-group">
            <label class="form-label">Service Type</label>
            <div class="form-row" style="gap:var(--space-3);">
              <label class="service-option" style="flex:1;cursor:pointer;">
                <input type="radio" name="serviceType" value="airport" checked style="display:none;" onchange="updateForm()">
                <div class="service-option-box" style="border:2px solid var(--color-gray-200);border-radius:var(--radius-md);padding:var(--space-4);text-align:center;transition:all var(--transition-fast);" onmouseenter="this.style.borderColor='var(--color-primary)'" onmouseleave="if(!this.previousElementSibling.checked)this.style.borderColor='var(--color-gray-200)'">
                  <div style="font-size:1.5rem;margin-bottom:var(--space-2);">✈</div>
                  <div style="font-weight:600;font-size:var(--text-sm);">Airport Transfer</div>
                </div>
              </label>
              <label class="service-option" style="flex:1;cursor:pointer;">
                <input type="radio" name="serviceType" value="city" style="display:none;" onchange="updateForm()">
                <div class="service-option-box" style="border:2px solid var(--color-gray-200);border-radius:var(--radius-md);padding:var(--space-4);text-align:center;transition:all var(--transition-fast);" onmouseenter="this.style.borderColor='var(--color-primary)'" onmouseleave="if(!this.previousElementSibling.checked)this.style.borderColor='var(--color-gray-200)'">
                  <div style="font-size:1.5rem;margin-bottom:var(--space-2);">🚗</div>
                  <div style="font-weight:600;font-size:var(--text-sm);">City / Hourly</div>
                </div>
              </label>
              <label class="service-option" style="flex:1;cursor:pointer;">
                <input type="radio" name="serviceType" value="intercity" style="display:none;" onchange="updateForm()">
                <div class="service-option-box" style="border:2px solid var(--color-gray-200);border-radius:var(--radius-md);padding:var(--space-4);text-align:center;transition:all var(--transition-fast);" onmouseenter="this.style.borderColor='var(--color-primary)'" onmouseleave="if(!this.previousElementSibling.checked)this.style.borderColor='var(--color-gray-200)'">
                  <div style="font-size:1.5rem;margin-bottom:var(--space-2);">🌄</div>
                  <div style="font-weight:600;font-size:var(--text-sm);">Intercity</div>
                </div>
              </label>
            </div>
          </div>

          <!-- City -->
          <div class="form-group">
            <label class="form-label" for="city">City</label>
            <select class="form-select" id="city" name="city" required onchange="updateAirportInfo()">
              <option value="" disabled selected>Select your city</option>
              <optgroup label="Top Entry Points (Most Popular)">
                <option value="shanghai">Shanghai — #1 International Entry</option>
                <option value="beijing">Beijing — Capital & Great Wall</option>
                <option value="xian">Xi'an — Terracotta Warriors</option>
                <option value="chengdu">Chengdu — Pandas & Culture</option>
                <option value="guangzhou">Guangzhou — Canton & Business</option>
                <option value="hangzhou">Hangzhou — West Lake</option>
                <option value="shenzhen">Shenzhen — Tech Hub</option>
                <option value="wuhan">Wuhan — Central China Hub</option>
              </optgroup>
              <optgroup label="Other Major Cities">
                <option value="nanjing">Nanjing</option>
                <option value="chongqing">Chongqing</option>
                <option value="suzhou">Suzhou</option>
                <option value="qingdao">Qingdao</option>
                <option value="xiamen">Xiamen</option>
                <option value="kunming">Kunming</option>
                <option value="tianjin">Tianjin</option>
                <option value="dalian">Dalian</option>
                <option value="changsha">Changsha</option>
                <option value="zhengzhou">Zhengzhou</option>
                <option value="harbin">Harbin</option>
                <option value="jinan">Jinan</option>
                <option value="wenzhou">Wenzhou</option>
                <option value="changchun">Changchun</option>
                <option value="shijiazhuang">Shijiazhuang</option>
                <option value="changzhou">Changzhou</option>
                <option value="quanzhou">Quanzhou</option>
                <option value="nanning">Nanning</option>
                <option value="guiyang">Guiyang</option>
                <option value="nanchang">Nanchang</option>
                <option value="nantong">Nantong</option>
                <option value="jinhua">Jinhua</option>
                <option value="xuzhou">Xuzhou</option>
                <option value="taiyuan">Taiyuan</option>
                <option value="jiaxing">Jiaxing</option>
                <option value="yantai">Yantai</option>
                <option value="baoding">Baoding</option>
                <option value="zhuhai">Zhuhai</option>
                <option value="zhongshan">Zhongshan</option>
                <option value="lanzhou">Lanzhou</option>
                <option value="linyi">Linyi</option>
                <option value="weifang">Weifang</option>
                <option value="shaoxing">Shaoxing</option>
                <option value="huizhou">Huizhou</option>
            </optgroup>
            </select>
          </div>

          <!-- Airport Fields -->
          <div class="form-group" id="airportFields">
            <div class="form-row">
              <div>
                <label class="form-label" for="airport">Airport *</label>
                <select class="form-select" id="airport" name="airport" required onchange="updateAirportInfo()">
                  <option value="" disabled selected>Select airport</option>
                </select>
                <p class="text-small" id="airportDistanceInfo" style="color:var(--color-gray-400);margin-top:var(--space-1);margin-bottom:0;"></p>
              </div>
              <div>
                <label class="form-label" for="transferDirection">Transfer Direction *</label>
                <select class="form-select" id="transferDirection" name="transferDirection" required onchange="updateForm()">
                  <option value="" disabled selected>Select direction</option>
                  <option value="airport-to-hotel">Airport → Hotel (Pickup)</option>
                  <option value="hotel-to-airport">Hotel → Airport (Drop-off)</option>
                </select>
              </div>
            </div>
            <div class="form-group" style="margin-top:var(--space-4);">
              <label class="form-label" for="hotelAddress">Hotel / Destination Address *</label>
              <input type="text" class="form-input" id="hotelAddress" name="hotelAddress" required placeholder="Hotel name or full address (e.g., Park Hyatt Shanghai, 100 Century Avenue)" oninput="updateForm()" onchange="updateForm()">
            </div>
            <div class="form-group" style="margin-top:var(--space-4);">
              <label class="form-label" for="distanceRange">Approximate Distance (km) *</label>
              <select class="form-select" id="distanceRange" name="distanceRange" required onchange="this.dataset.userChanged='true'; updateForm();">
                <option value="" disabled selected>Select distance range</option>
                <option value="0-30">0–30 km (≈ $35–$50 Economy)</option>
                <option value="30-50">30–50 km (≈ $45–$65 Economy)</option>
                <option value="50-80">50–80 km (≈ $55–$80 Economy)</option>
                <option value="80+">80+ km (≈ $70–$100 Economy)</option>
              </select>
              <p class="text-small" style="color:var(--color-gray-400);margin-top:var(--space-1);">Distance is pre-filled based on airport. Adjust if your hotel is far from the city center.</p>
            </div>
          </div>

          <div class="form-group" id="cityFields" style="display:none;">
            <div class="form-row">
              <div>
                <label class="form-label" for="hours">Hours Needed</label>
                <select class="form-select" id="hours" name="hours" onchange="updateForm()">
                  <option value="4">4 hours</option>
                  <option value="8" selected>8 hours</option>
                  <option value="12">12 hours</option>
                  <option value="custom">Custom</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="cityDistanceRange">Trip Distance (km)</label>
                <select class="form-select" id="cityDistanceRange" name="cityDistanceRange" onchange="updateForm()">
                  <option value="0-150" selected>Within City (0–150 km)</option>
                  <option value="150-300">Suburban (150–300 km)</option>
                  <option value="300-500">Outside City (300–500 km)</option>
                </select>
              </div>
            </div>
            <div class="form-row" style="margin-top:var(--space-4);">
              <div style="flex:1;">
                <label class="form-label" for="cityRoute">Route / Area</label>
                <input type="text" class="form-input" id="cityRoute" name="cityRoute" placeholder="e.g., Downtown sightseeing, Great Wall, Zhouzhuang">
                <p class="text-small" style="color:var(--color-gray-400);margin-top:var(--space-1);">Tell us where you're going and we'll estimate the distance range.</p>
              </div>
            </div>
          </div>

          <div class="form-group" id="intercityFields" style="display:none;">
            <div class="form-row">
              <div>
                <label class="form-label" for="fromCity">From</label>
                <input type="text" class="form-input" id="fromCity" name="fromCity" placeholder="e.g., Beijing">
              </div>
              <div>
                <label class="form-label" for="toCity">To</label>
                <input type="text" class="form-input" id="toCity" name="toCity" placeholder="e.g., Great Wall">
              </div>
            </div>
          </div>

          <!-- Custom Address (conditional) -->
          <div class="form-group" id="customAddressGroup" style="display:none;">
            <label class="form-label" for="customAddress">Custom Address</label>
            <input type="text" class="form-input" id="customAddress" name="customAddress" placeholder="Hotel name or full address">
          </div>

          <!-- Date & Time -->
          <div class="form-group">
            <div class="form-row">
              <div>
                <label class="form-label" for="date">Date</label>
                <input type="date" class="form-input" id="date" name="date" required>
              </div>
              <div>
                <label class="form-label" for="time">Time</label>
                <input type="time" class="form-input" id="time" name="time" required>
              </div>
            </div>
          </div>

          <!-- Vehicle Type -->
          <div class="form-group">
            <label class="form-label">Vehicle Type</label>
            <div class="form-row" style="gap:var(--space-3);">
              <label class="vehicle-option" style="flex:1;cursor:pointer;">
                <input type="radio" name="vehicle" value="economy" checked style="display:none;" onchange="updateForm()">
                <div class="vehicle-option-box" style="border:2px solid var(--color-gray-200);border-radius:var(--radius-md);padding:var(--space-4);transition:all var(--transition-fast);" onmouseenter="this.style.borderColor='var(--color-primary)'" onmouseleave="if(!this.previousElementSibling.checked)this.style.borderColor='var(--color-gray-200)'">
                  <div style="font-size:1.25rem;font-weight:700;color:var(--color-primary);margin-bottom:var(--space-1);">Economy</div>
                  <div style="font-size:var(--text-xs);color:var(--color-gray-500);">Sedan · 3 pax · 2 bags</div>
                  <div class="vehicle-price" style="font-weight:700;color:var(--color-primary);margin-top:var(--space-2);" data-base="50">From $50</div>
                </div>
              </label>
              <label class="vehicle-option" style="flex:1;cursor:pointer;">
                <input type="radio" name="vehicle" value="business" style="display:none;" onchange="updateForm()">
                <div class="vehicle-option-box" style="border:2px solid var(--color-gray-200);border-radius:var(--radius-md);padding:var(--space-4);transition:all var(--transition-fast);" onmouseenter="this.style.borderColor='var(--color-primary)'" onmouseleave="if(!this.previousElementSibling.checked)this.style.borderColor='var(--color-gray-200)'">
                  <div style="font-size:1.25rem;font-weight:700;color:var(--color-primary);margin-bottom:var(--space-1);">Business</div>
                  <div style="font-size:var(--text-xs);color:var(--color-gray-500);">Premium · 3 pax · 2 bags</div>
                  <div class="vehicle-price" style="font-weight:700;color:var(--color-primary);margin-top:var(--space-2);" data-base="80">From $80</div>
                </div>
              </label>
              <label class="vehicle-option" style="flex:1;cursor:pointer;">
                <input type="radio" name="vehicle" value="mpv" style="display:none;" onchange="updateForm()">
                <div class="vehicle-option-box" style="border:2px solid var(--color-gray-200);border-radius:var(--radius-md);padding:var(--space-4);transition:all var(--transition-fast);" onmouseenter="this.style.borderColor='var(--color-primary)'" onmouseleave="if(!this.previousElementSibling.checked)this.style.borderColor='var(--color-gray-200)'">
                  <div style="font-size:1.25rem;font-weight:700;color:var(--color-primary);margin-bottom:var(--space-1);">MPV</div>
                  <div style="font-size:var(--text-xs);color:var(--color-gray-500);">Van · 6 pax · 4 bags</div>
                  <div class="vehicle-price" style="font-weight:700;color:var(--color-primary);margin-top:var(--space-2);" data-base="105">From $105</div>
                </div>
